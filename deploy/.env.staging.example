# staging 环境示例，建议使用接近生产的外部依赖，并默认关闭文档与调试入口。
AUBB_APP_IMAGE=ghcr.io/example/aubb-server:sha-abcdef1
AUBB_APP_PORT=18080

SPRING_DATASOURCE_URL=jdbc:postgresql://staging-postgres.internal:5432/aubb
SPRING_DATASOURCE_USERNAME=aubb
SPRING_DATASOURCE_PASSWORD=replace-me

AUBB_JWT_SECRET=replace-with-at-least-32-characters

SPRING_RABBITMQ_HOST=staging-rabbitmq.internal
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=aubb
SPRING_RABBITMQ_PASSWORD=replace-me
AUBB_JUDGE_QUEUE_ENABLED=true
AUBB_JUDGE_QUEUE_PUBLISHER_ENABLED=true
AUBB_JUDGE_QUEUE_CONSUMER_ENABLED=true
AUBB_JUDGE_QUEUE_NAME=aubb.judge.jobs
AUBB_JUDGE_QUEUE_DLQ_NAME=aubb.judge.jobs.dlq
AUBB_JUDGE_QUEUE_DLX=aubb.judge.jobs.dlx
AUBB_JUDGE_QUEUE_CONCURRENCY=4
AUBB_JUDGE_QUEUE_PREFETCH=8
AUBB_JUDGE_QUEUE_MAX_ATTEMPTS=3
AUBB_DEPLOY_ENV=staging
AUBB_TRACING_ENABLED=true
AUBB_TRACING_SAMPLING_PROBABILITY=1.0
AUBB_OTLP_TRACING_ENDPOINT=http://staging-otel-collector.internal:4318/v1/traces

AUBB_MINIO_ENABLED=true
AUBB_MINIO_ENDPOINT=http://staging-minio.internal:9000
AUBB_MINIO_ACCESS_KEY=aubbminio
AUBB_MINIO_SECRET_KEY=replace-me
AUBB_MINIO_BUCKET=aubb-assets-staging
AUBB_MINIO_AUTO_CREATE_BUCKET=false

AUBB_GO_JUDGE_ENABLED=true
AUBB_GO_JUDGE_BASE_URL=http://staging-go-judge.internal:5050

AUBB_REDIS_ENABLED=true
AUBB_REDIS_HOST=staging-redis.internal
AUBB_REDIS_PORT=6379
AUBB_REDIS_PASSWORD=replace-me
AUBB_REDIS_DATABASE=0
AUBB_REDIS_NAMESPACE=aubb
AUBB_REDIS_RATE_LIMIT_ENABLED=true
AUBB_REDIS_REALTIME_ENABLED=true

AUBB_API_DOCS_ENABLED=false
AUBB_SWAGGER_UI_ENABLED=false
AUBB_BOOTSTRAP_ENABLED=false
